<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<VBox xmlns:fx="http://javafx.com/fxml/1"
      spacing="12"
      style="-fx-padding: 20; -fx-background-color: #F4F6F9;"
      prefWidth="700" prefHeight="450" >

    <!-- Título -->
    <Label text="Gestión de Finanzas Personales"
           style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <TableView fx:id="tablaOperaciones" VBox.vgrow="ALWAYS">

        <placeholder>
            <Label text="No hay operaciones registradas."
                   style="-fx-text-fill: #9E9E9E; -fx-font-style: italic;"/>
        </placeholder>

        <columns>

            <TableColumn fx:id="colTipo"         text="Tipo"               prefWidth="100"/>
            <TableColumn fx:id="colDescripcion"  text="Descripción"        prefWidth="220"/>
            <TableColumn fx:id="colImporte"      text="Importe (€)"        prefWidth="110"/>
            <TableColumn fx:id="colFecha"        text="Fecha"              prefWidth="110"/>
            <TableColumn fx:id="colOrigen"       text="Origen / Categoría" prefWidth="160"/>
        </columns>
    </TableView>

    <Button fx:id="btnNuevaOperacion"
            text="+ Nueva Operación"
            prefWidth="180"
            style="-fx-background-color: #1A237E; -fx-text-fill: white;
                   -fx-font-weight: bold; -fx-font-size: 13px;"/>

</VBox>
