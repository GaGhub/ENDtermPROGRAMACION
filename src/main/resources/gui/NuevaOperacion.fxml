<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      spacing="14"
      style="-fx-padding: 24; -fx-background-color: white;"
      prefWidth="380">

    <!-- Título -->
    <Label text="Nueva Operación"
           style="-fx-font-size: 17px; -fx-font-weight: bold;"/>

    <Separator/>

    <VBox spacing="4">
        <Label text="Tipo: *"/>
        <ComboBox fx:id="cmbTipo"
                  promptText="Selecciona tipo"
                  maxWidth="Infinity"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Descripción (opcional):"/>
        <TextField fx:id="txtDescripcion"
                   promptText="Ej: Nómina Marzo, Netflix, …"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Importe (€): *"/>
        <TextField fx:id="txtImporte"
                   promptText="0.00"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Fecha: *"/>
        <DatePicker fx:id="dpFecha"
                    promptText="dd/mm/aaaa"
                    maxWidth="Infinity"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Origen / Categoría: *"/>
        <TextField fx:id="txtOrigen"
                   promptText="Ej: Nómina, Alimentación, Ocio, …"/>
    </VBox>

    <Separator/>

    <HBox spacing="10">
        <Button fx:id="btnGuardar"
                text="Guardar"
                defaultButton="true"
                maxWidth="Infinity"
                HBox.hgrow="ALWAYS"
                style="-fx-background-color: #1A237E; -fx-text-fill: white; -fx-font-weight: bold;"/>

        <Button fx:id="btnCancelar"
                text="Cancelar"
                cancelButton="true"
                maxWidth="Infinity"
                HBox.hgrow="ALWAYS"/>
    </HBox>

    <Label fx:id="lblError"
           text=""
           style="-fx-text-fill: #C62828; -fx-font-size: 12px;"
           wrapText="true"/>

</VBox>
